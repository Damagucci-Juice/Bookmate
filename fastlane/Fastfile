default_platform(:ios)

platform :ios do

  # ── Test lane ──────────────────────────────────────
  desc "Run unit tests"
  lane :test do
    scan(
      project: "Bookmate/Bookmate.xcodeproj",
      scheme: "Bookmate",
      destination: "platform=iOS Simulator,name=iPhone 16 Pro,OS=26.1",
      clean: true,
      code_coverage: true,
      output_directory: "./fastlane/test_output",
      result_bundle: true
    )
  end

  # ── Beta lane (TestFlight) ─────────────────────────
  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    match(type: "appstore", readonly: is_ci)

    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || (latest_testflight_build_number(api_key: api_key) + 1).to_s,
      xcodeproj: "Bookmate/Bookmate.xcodeproj"
    )

    gym(
      project: "Bookmate/Bookmate.xcodeproj",
      scheme: "Bookmate",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      clean: true
    )

    deliver(
      api_key: api_key,
      skip_metadata: true,
      skip_screenshots: true,
      force: true
    )
  end

  # ── Release lane (App Store 심사 제출) ──────────────
  desc "Build and submit for App Store review"
  lane :release do
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    match(type: "appstore", readonly: is_ci)

    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || (latest_testflight_build_number(api_key: api_key) + 1).to_s,
      xcodeproj: "Bookmate/Bookmate.xcodeproj"
    )

    gym(
      project: "Bookmate/Bookmate.xcodeproj",
      scheme: "Bookmate",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      clean: true
    )

    deliver(
      api_key: api_key,
      submit_for_review: true,
      automatic_release: false,
      force: true
    )
  end
end
